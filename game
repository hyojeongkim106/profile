import streamlit as st
import random
import time

st.set_page_config(page_title="두더지 게임", page_icon="🐹")

# 초기값
if "score" not in st.session_state:
    st.session_state.score = 0

if "mole" not in st.session_state:
    st.session_state.mole = random.randint(0, 8)

if "start_time" not in st.session_state:
    st.session_state.start_time = time.time()

if "game_over" not in st.session_state:
    st.session_state.game_over = False

GAME_TIME = 30

elapsed = int(time.time() - st.session_state.start_time)
remaining = max(0, GAME_TIME - elapsed)

if remaining == 0:
    st.session_state.game_over = True

st.title("🐹 두더지 게임")

col1, col2 = st.columns(2)
col1.metric("점수", st.session_state.score)
col2.metric("남은 시간", f"{remaining}초")

st.write("---")

if not st.session_state.game_over:

    cols = st.columns(3)

    for i in range(9):

        if i % 3 == 0 and i != 0:
            cols = st.columns(3)

        col = cols[i % 3]

        with col:

            if i == st.session_state.mole:
                text = "🐹"
            else:
                text = "🟩"

            if st.button(text, key=i):

                if i == st.session_state.mole:
                    st.session_state.score += 1
                    st.session_state.mole = random.randint(0, 8)
                    st.rerun()

else:
    st.success(f"게임 종료! 최종 점수 : {st.session_state.score}")

    if st.button("다시 시작"):
        st.session_state.score = 0
        st.session_state.start_time = time.time()
        st.session_state.mole = random.randint(0, 8)
        st.session_state.game_over = False
        st.rerun()
